{
  "name": "amancha_wedding",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --ext .ts,.tsx,.js,.jsx src",
    "prepare": "lefthook install",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "lint-staged": "lint-staged",
    "format": "npm run prettier:write && npm run lint-staged",
    "test": "echo \"No tests configured.\"",
    "vercel:check": "node ./scripts/check-env.js"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "leaflet": "^1.9.4",
    "next": "16.0.10",
    "nodemailer": "^7.0.11",
    "react": "19.2.1",
    "react-dom": "19.2.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@playwright/test": "^1.57.0",
    "@prisma/client": "^6.19.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "eslint-plugin-security": "^3.0.1",
    "lefthook": "^2.0.11",
    "lint-staged": "^16.2.7",
    "playwright": "^1.57.0",
    "prettier": "^3.7.4",
    "prisma": "^7.1.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "zod": "^4.1.13"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix",
      "git add"
    ],
    "**/*.{css,scss}": [
      "prettier --write",
      "git add"
    ],
    "**/*.{md,json,html}": [
      "prettier --write",
      "git add"
    ]
  }
}
